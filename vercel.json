{
  "version": 2,
  "buildCommand": "cd frontend && npm ci && npm run build:prod",
  "outputDirectory": "frontend/dist/regicide-frontend/browser",
  "devCommand": "cd frontend && npm start",
  "installCommand": "cd frontend && npm ci",
  "env": {
    "BACKEND_URL": "@backend-url",
    "API_URL": "@api-url"
  },
  "regions": ["sfo1"],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
