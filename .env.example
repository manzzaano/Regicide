# Backend — Production Environment Variables
# Copiar a .env y llenar valores reales

# Database (Railway proporciona estos)
DB_HOST=your-railway-postgres-host
DB_PORT=5432
DB_NAME=regicide
DB_USER=postgres
DB_PASSWORD=your-secure-password

# JWT Secret (generar con: openssl rand -base64 64)
JWT_SECRET=your-secure-jwt-secret-minimum-64-chars

# CORS
CORS_ORIGIN=https://your-vercel-frontend-domain.com

# Spring
SPRING_PROFILES_ACTIVE=prod
